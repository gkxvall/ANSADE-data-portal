# PostgreSQL connection used by Prisma. Replace each placeholder locally.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Only the PostgreSQL provider is supported until Stage 4.
DATA_SOURCE="postgres"

# Reserved for the future API provider. Optional in Stage 1.
ANSADE_API_BASE_URL=""
ANSADE_API_TOKEN=""

# Safe to expose in the browser. Keep secrets out of NEXT_PUBLIC_* variables.
NEXT_PUBLIC_APP_NAME="ANSADE Statistical Data Explorer"
